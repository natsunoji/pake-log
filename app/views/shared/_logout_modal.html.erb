<div id="logout-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-6 transition-all">
  <%# 背景のぼかし %>
  <div class="absolute inset-0 bg-primary/40 backdrop-blur-sm" onclick="closeLogoutModal()"></div>
  
  <div class="relative bg-white w-full max-w-xs rounded-[32px] overflow-hidden shadow-2xl">
    <div class="pt-10 pb-6 px-6 text-center">
      <div class="w-14 h-14 bg-base-bg text-primary rounded-full flex items-center justify-center mx-auto mb-5">
        <i class="bi bi-box-arrow-right text-2xl ml-1"></i>
      </div>
      <h3 class="text-xl font-black text-primary mb-3">ログアウトしますか？</h3>
      <p class="text-[12px] text-base-text leading-relaxed font-bold opacity-60 px-2">
        セッションを終了します。<br>またのご利用をお待ちしております！
      </p>
    </div>
    
    <div class="flex border-t border-base-border h-16">
      <button onclick="closeLogoutModal()" class="flex-1 text-primary text-sm font-black hover:bg-base-bg transition-colors border-r border-base-border cursor-pointer">
        キャンセル
      </button>
      <%# 🌟 onclick="closeLogoutModal()" を追加してスクロール禁止を解除してから遷移させる %>
      <%= link_to destroy_user_session_path, 
          data: { turbo_method: :delete }, 
          onclick: "closeLogoutModal()",
          class: "flex-1 h-full text-white bg-primary text-sm font-black flex items-center justify-center active:opacity-90 transition-opacity cursor-pointer" do %>
        ログアウト
      <% end %>
    </div>
  </div>
</div>

<script>
  function openLogoutModal() {
    const modal = document.getElementById('logout-modal');
    if (modal) {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }
  function closeLogoutModal() {
    const modal = document.getElementById('logout-modal');
    if (modal) {
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
    }
  }

  document.addEventListener("turbo:before-cache", function() {
    closeLogoutModal();
  });
</script>