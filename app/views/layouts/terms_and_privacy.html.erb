<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>PakeLog | 規約</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  </head>
  <%# 🌟 修正：h-screen や overflow-hidden を全て削除し、標準のスクロールに戻します %>
  <body class="bg-white text-text-main font-sans min-h-screen">
    <div class="max-w-screen-md mx-auto bg-white flex flex-col min-h-screen">
      <%= yield %>
    </div>
  </body>
</html>