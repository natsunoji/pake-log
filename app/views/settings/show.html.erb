<%# 🌟 ヘッダー：共通パーツを使用。back_path を指定して戻るボタンを表示 %>
<%= render 'shared/header', title: "設定", back_path: authenticated_root_path %>

<main class="flex-1 px-4 py-8 flex flex-col gap-8 pb-32 bg-base-bg">
  
  <%# 🌟 ユーザープロフィールカード %>
  <div class="bg-white rounded-[32px] p-6 shadow-sm border border-primary/5">
    <div class="flex items-center gap-5">
      <div class="w-16 h-16 rounded-full bg-base-bg flex items-center justify-center border-2 border-white shadow-sm overflow-hidden text-primary text-3xl">
        <i class="bi bi-person-fill"></i>
      </div>
      
      <div class="flex flex-col">
        <p class="text-primary text-xl font-black leading-tight"><%= current_user.name %></p>
        <p class="text-base-text font-bold opacity-60 text-xs mt-1"><%= current_user.email %></p>
      </div>
    </div>
  </div>

  <%# 🌟 アカウント設定セクション %>
  <div class="flex flex-col gap-3">
    <p class="text-primary/40 text-[10px] font-black uppercase tracking-[0.2em] px-4">Account</p>
    
    <%= link_to edit_user_registration_path, class: "group flex items-center justify-between p-5 bg-white rounded-3xl border border-primary/5 shadow-sm active:scale-[0.98] transition-all" do %>
      <div class="flex items-center gap-4">
        <div class="flex items-center justify-center w-11 h-11 rounded-2xl bg-info-light text-info">
          <i class="bi bi-person-fill text-xl"></i>
        </div>
        <span class="text-primary font-bold text-base">プロフィール設定</span>
      </div>
      <i class="bi bi-chevron-right text-primary/20 group-hover:text-primary transition-colors"></i>
    <% end %>
  </div>

  <%# 🌟 サポートセクション %>
  <div class="flex flex-col gap-3">
    <p class="text-primary/40 text-[10px] font-black uppercase tracking-[0.2em] px-4">Support</p>
    
    <%# 🌟 お問い合わせ：リンク先を contact_path に変更 %>
    <%= link_to contact_path, class: "group flex items-center justify-between p-5 bg-white rounded-3xl border border-primary/5 shadow-sm active:scale-[0.98] transition-all" do %>
      <div class="flex items-center gap-4">
        <div class="flex items-center justify-center w-11 h-11 rounded-2xl bg-notice-light text-notice">
          <i class="bi bi-question-circle-fill text-xl"></i>
        </div>
        <span class="text-primary font-bold text-base">お問い合わせ</span>
      </div>
      <i class="bi bi-chevron-right text-primary/20 group-hover:text-primary transition-colors"></i>
    <% end %>

    <%= link_to terms_path, class: "group flex items-center justify-between p-5 bg-white rounded-3xl border border-primary/5 shadow-sm active:scale-[0.98] transition-all" do %>
      <div class="flex items-center gap-4">
        <div class="flex items-center justify-center w-11 h-11 rounded-2xl bg-success-light text-success">
          <i class="bi bi-file-text-fill text-xl"></i>
        </div>
        <span class="text-primary font-bold text-base">利用規約</span>
      </div>
      <i class="bi bi-chevron-right text-primary/20 group-hover:text-primary transition-colors"></i>
    <% end %>

    <%= link_to privacy_path, class: "group flex items-center justify-between p-5 bg-white rounded-3xl border border-primary/5 shadow-sm active:scale-[0.98] transition-all" do %>
      <div class="flex items-center gap-4">
        <div class="flex items-center justify-center w-11 h-11 rounded-2xl bg-success-light text-success">
          <i class="bi bi-shield-lock-fill text-xl"></i>
        </div>
        <span class="text-primary font-bold text-base">プライバシーポリシー</span>
      </div>
      <i class="bi bi-chevron-right text-primary/20 group-hover:text-primary transition-colors"></i>
    <% end %>
  </div>

  <%# 🌟 ログアウトボタン %>
  <div class="px-2 mt-4">
    <button onclick="openLogoutModal()" class="w-full group flex items-center justify-between p-5 bg-danger-light rounded-3xl border border-danger/10 active:scale-[0.98] transition-all">
      <div class="flex items-center gap-4">
        <div class="flex items-center justify-center w-11 h-11 rounded-2xl bg-danger-light text-danger">
          <i class="bi bi-box-arrow-right text-xl"></i>
        </div>
        <span class="font-bold text-base text-danger">ログアウト</span>
      </div>
    </button>
  </div>

  <p class="text-center text-[10px] text-primary/30 font-bold tracking-widest mt-6 mb-10">
    Version 1.0.0 (Build 20260324)
  </p>
</main>