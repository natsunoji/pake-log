<div class="max-w-md mx-auto px-6 py-8">
  <div class="text-center mb-10">
    <h2 class="text-2xl font-black text-primary mb-2">パスワードをお忘れですか？</h2>
    <p class="text-sm text-base-text font-bold opacity-60">ご登録のメールアドレスを入力してください。<br>再設定用のリンクをお送りします。</p>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%# 🌟 devise/shared/error_messages は、config.paranoid = true にすると %>
    <%# 「登録がない」エラーは出さなくなるので、このままでOKです %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-8">
      <%= f.label :email, "メールアドレス", class: "text-sm font-bold text-primary block mb-2 ml-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", 
          placeholder: "example@pakelog.com",
          class: "w-full px-5 py-4 border-none rounded-2xl bg-base-bg text-primary text-base focus:ring-2 focus:ring-accent shadow-inner font-bold outline-none transition-all placeholder:opacity-30" %>
    </div>

    <div class="space-y-4">
      <%= f.submit "再設定メールを送信する", 
          class: "w-full bg-primary text-white font-black py-5 rounded-full text-lg shadow-lg active:translate-y-0.5 transition-all tracking-widest cursor-pointer" %>
      
      <%= link_to "ログイン画面に戻る", new_session_path(resource_name), 
          class: "block text-center text-sm font-bold text-base-text hover:text-primary transition-colors py-2" %>
    </div>
  <% end %>
</div>