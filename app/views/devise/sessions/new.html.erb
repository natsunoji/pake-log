<%# 🌟 外側の min-h-screen や不要な余白を削ぎ落としたお掃除版である！ %>
<div class="max-w-md mx-auto w-full px-6 py-8">
  
  <%# ヘッダー部分 %>
  <div class="text-center mb-10">
    <h2 class="text-2xl font-black text-primary mb-2">ログイン</h2>
    <p class="text-sm text-base-text font-bold opacity-60">
      おかえりなさい！<br>登録した情報を入力してログインしてください。
    </p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    
    <%# メールアドレス %>
    <div class="mb-5">
      <%= f.label :email, "メールアドレス", class: "block text-sm font-bold text-primary mb-2 ml-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@pakelog.com",
          class: "w-full px-5 py-4 border-none rounded-2xl bg-base-bg text-primary text-base focus:ring-2 focus:ring-accent shadow-inner font-bold outline-none transition-all placeholder:opacity-30" %>
    </div>

    <%# パスワード %>
    <div class="mb-5" data-controller="password-visibility">
      <%= f.label :password, "パスワード", class: "block text-sm font-bold text-primary mb-2 ml-1" %>
      <div class="relative flex items-center">
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••",
            data: { password_visibility_target: "input" },
            class: "w-full px-5 py-4 border-none rounded-2xl bg-base-bg text-primary text-base focus:ring-2 focus:ring-accent shadow-inner font-bold pr-14 outline-none transition-all placeholder:opacity-30" %>
        
        <button type="button" 
                data-action="password-visibility#toggle" 
                class="absolute right-4 text-gray-400 focus:outline-none hover:text-primary transition-colors cursor-pointer">
          <i class="bi bi-eye-slash text-xl" data-password-visibility-target="icon"></i>
        </button>
      </div>
    </div>

    <%# ログイン情報保持 %>
    <% if devise_mapping.rememberable? %>
      <div class="flex items-center mb-8 ml-1">
        <label class="flex items-center cursor-pointer group">
          <%= f.check_box :remember_me, 
              class: "appearance-none w-5 h-5 flex-shrink-0 rounded-lg bg-base-bg checked:bg-accent border-none shadow-inner cursor-pointer transition-all duration-200 relative
                      after:content-[''] after:absolute after:hidden checked:after:block after:left-[7px] after:top-[3px] after:w-[5px] after:h-[10px] after:border-white after:border-r-2 after:border-b-2 after:rotate-45" %>
          <span class="ml-3 text-sm text-base-text font-bold opacity-70 group-hover:opacity-100 transition-opacity">
            ログイン情報を保存する
          </span>
        </label>
      </div>
    <% end %>

    <%# ログインボタン %>
    <div class="mb-10">
      <%= f.submit "ログイン", class: "w-full bg-primary text-white font-black py-5 rounded-full text-lg shadow-lg active:translate-y-0.5 transition-all tracking-widest cursor-pointer" %>
    </div>
  <% end %>

  <div class="text-center font-bold">
    <%= render "devise/shared/links" %>
  </div>
</div>