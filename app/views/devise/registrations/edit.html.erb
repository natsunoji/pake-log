<div class="min-h-screen bg-white pb-32">
  <%# --- 1. Sharedヘッダー呼び出し（戻る先はライブラリ） --- %>
  <%= render 'shared/header', title: "プロフィール編集", back_path: items_path %>

  <div class="px-6 py-8 max-w-md mx-auto">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%# お名前 %>
      <div class="mb-6">
        <%= f.label :name, "お名前", class: "block text-sm font-bold text-primary mb-2 ml-1" %>
        <%= f.text_field :name, autofocus: true, 
            class: "w-full px-5 py-4 border-none rounded-2xl bg-base-bg text-primary text-base focus:ring-2 focus:ring-accent shadow-inner font-bold" %>
      </div>

      <%# メールアドレス（読み取り専用） %>
      <div class="mb-8">
        <%= f.label :email, "メールアドレス", class: "block text-sm font-bold text-gray-400 mb-2 ml-1" %>
        <%= f.email_field :email, readonly: true, 
            class: "w-full px-5 py-4 border-none rounded-2xl bg-gray-100 text-gray-400 text-base cursor-not-allowed font-bold" %>
        <p class="text-[10px] text-gray-400 mt-2 ml-1 font-bold">※メールアドレスの変更は現在対応しておりません</p>
      </div>

      <hr class="my-10 border-base-border">

      <%# 新しいパスワード %>
      <div class="mb-6" data-controller="password-visibility">
        <%= f.label :password, "新しいパスワード", class: "block text-sm font-bold text-primary mb-1 ml-1" %>
        <span class="text-[10px] text-base-text font-bold opacity-60 mb-2 block ml-1">※変更しない場合は空欄のままにしてください</span>
        <div class="relative flex items-center">
          <%= f.password_field :password, autocomplete: "new-password", 
              data: { password_visibility_target: "input" },
              class: "w-full px-5 py-4 border-none rounded-2xl bg-base-bg text-primary text-base focus:ring-2 focus:ring-accent shadow-inner font-bold pr-14" %>
          <button type="button" data-action="password-visibility#toggle" class="absolute right-4 text-gray-400 focus:outline-none hover:text-primary cursor-pointer">
            <i class="bi bi-eye-slash text-xl" data-password-visibility-target="icon"></i>
          </button>
        </div>
      </div>

      <%# パスワード確認用 %>
      <div class="mb-10" data-controller="password-visibility">
        <%= f.label :password_confirmation, "確認用パスワード", class: "block text-sm font-bold text-primary mb-2 ml-1" %>
        <div class="relative flex items-center">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", 
              data: { password_visibility_target: "input" },
              class: "w-full px-5 py-4 border-none rounded-2xl bg-base-bg text-primary text-base focus:ring-2 focus:ring-accent shadow-inner font-bold pr-14" %>
          <button type="button" data-action="password-visibility#toggle" class="absolute right-4 text-gray-400 focus:outline-none hover:text-primary cursor-pointer">
            <i class="bi bi-eye-slash text-xl" data-password-visibility-target="icon"></i>
          </button>
        </div>
      </div>

      <%# 現在のパスワード（重要） %>
      <div class="mb-10 p-6 bg-rose-50 rounded-3xl border border-rose-100" data-controller="password-visibility">
        <%= f.label :current_password, "現在のパスワード", class: "block text-sm font-bold text-rose-800 mb-2 ml-1" %>
        <div class="relative flex items-center">
          <%= f.password_field :current_password, autocomplete: "current-password", 
              data: { password_visibility_target: "input" },
              class: "w-full px-5 py-4 border-none rounded-2xl bg-white text-primary text-base focus:ring-2 focus:ring-rose-500 shadow-sm font-bold pr-14" %>
          <button type="button" data-action="password-visibility#toggle" class="absolute right-4 text-rose-300 focus:outline-none hover:text-rose-500 cursor-pointer">
            <i class="bi bi-eye-slash text-xl" data-password-visibility-target="icon"></i>
          </button>
        </div>
        <p class="text-[10px] text-rose-700/60 mt-3 ml-1 font-bold">設定変更には現在のパスワード入力が必要です</p>
      </div>

      <div class="mb-12">
        <%= f.submit "変更を保存する", class: "w-full bg-primary text-white font-black py-5 rounded-full text-lg shadow-lg active:translate-y-0.5 transition-all tracking-widest cursor-pointer" %>
      </div>
    <% end %>

    <div class="pt-8 border-t border-base-border text-center">
      <%= button_to "アカウントを完全に削除する", registration_path(resource_name), 
          data: { confirm: "本当に削除しますか？", turbo_confirm: "本当に削除しますか？" }, 
          method: :delete, 
          class: "text-sm text-rose-500 font-bold hover:underline" %>
    </div>
  </div>
</div>