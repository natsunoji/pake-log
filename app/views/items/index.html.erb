<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>
<div class="bg-gray-100 min-h-screen font-sans antialiased text-primary">
  
  <%# --- 1. ヘッダー & カテゴリタブエリア --- %>
  <%= render 'shared/header' %>

  <div class="px-3 pt-4 mb-2">
    <%= search_form_for @q, url: items_path, method: :get do |f| %>
      <div class="relative group">
        <%# 虫眼鏡アイコン %>
        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
          <i class="bi bi-search text-gray-400 group-focus-within:text-accent transition-colors"></i>
        </div>

        <%# 検索入力欄：名前(name)とメモ(memo)を同時検索 %>
        <%= f.search_field :name_or_memo_cont, 
            placeholder: "パケの名前 や メモで検索 ...", 
            class: "w-full pl-14 pr-4 py-4 rounded-2xl bg-white border-none text-primary text-sm font-bold shadow-sm focus:ring-2 focus:ring-accent transition-all placeholder:text-gray-300" %>
        
        <%# 重要：カテゴリで絞り込んでいる最中なら、そのカテゴリIDを隠しパラメータで保持する %>
        <% if params.dig(:q, :category_id_eq).present? %>
          <%= f.hidden_field :category_id_eq, value: params.dig(:q, :category_id_eq) %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# アイテムが存在するとき、または検索・フィルタリング中の時だけタブを表示 %>
  <% if @items.any? || params[:q].present? %>
    <div class="bg-white/95 backdrop-blur-md border-b border-base-border/50 sticky top-16 z-30 pb-3 pt-2">
      <div class="flex items-center px-3 gap-2">
        <%# --- カテゴリタブ（スクロールエリア） --- %>
        <div class="flex-grow flex overflow-x-auto space-x-2 no-scrollbar">
          <% all_active = params[:q].blank? || params.dig(:q, :category_id_eq).blank? %>
          <%= link_to items_path, 
              class: "#{all_active ? 'bg-accent border-accent' : 'bg-gray-100 border-transparent'} text-primary px-6 py-2 rounded-full text-sm font-bold whitespace-nowrap border transition-all shadow-sm active:scale-95" do %>
            全て
          <% end %>

          <% @categories.each do |category| %>
            <% is_active = params.dig(:q, :category_id_eq).to_s == category.id.to_s %>
            <%= link_to items_path(q: { category_id_eq: category.id }), 
                class: "#{is_active ? 'bg-accent border-accent' : 'bg-gray-100 border-transparent'} text-primary px-6 py-2 rounded-full text-sm font-bold whitespace-nowrap border transition-all shadow-sm active:scale-95" do %>
              <%= category.name %>
            <% end %>
          <% end %>
        </div>

        <%# --- カテゴリ管理ボタン（固定配置） --- %>
        <%= link_to categories_path, 
            class: "flex-shrink-0 w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-primary shadow-sm active:scale-90 transition-all border border-transparent" do %>
          <i class="bi bi-gear-fill"></i>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# --- 2. リスト部分 --- %>
  <div class="px-3 py-5 space-y-4 pb-32">
    <% if @items.empty? %>
      <% if params[:q].present? %>
        <%# 検索結果が空の場合 %>
        <div class="text-center py-20 bg-white rounded-3xl mx-2 border border-base-border shadow-sm">
          <i class="bi bi-search text-4xl text-gray-200 mb-4 block"></i>
          <p class="text-base-text font-bold opacity-60">パケは見つかりませんでした</p>
        </div>
      <% else %>
        <%# 🌟 Empty State：3ステップ案内 + 具体例チップ 🌟 %>
        <div class="flex flex-col items-center justify-center py-10 px-4">
          <div class="max-w-md w-full text-center">
            <h2 class="text-xl font-black text-[#11243B] mb-12">PakeLogの使い方</h2>

            <%# 3ステップ案内 %>
            <div class="flex items-start justify-between relative mb-12 px-2">
              <div class="absolute top-8 left-0 right-0 h-0.5 bg-gray-200 z-0"></div>

              <%# STEP 1 %>
              <div class="flex flex-col items-center relative z-10 w-1/3">
                <div class="w-16 h-16 bg-white border border-gray-100 rounded-full shadow-md flex items-center justify-center mb-4">
                  <i class="bi bi-camera text-2xl text-[#11243B]"></i>
                </div>
                <p class="text-[10px] font-bold text-gray-600 leading-tight">1. 写真を撮る</p>
              </div>

              <%# STEP 2 %>
              <div class="flex flex-col items-center relative z-10 w-1/3">
                <div class="w-16 h-16 bg-white border border-gray-100 rounded-full shadow-md flex items-center justify-center mb-4">
                  <i class="bi bi-file-earmark-plus text-2xl text-[#11243B]"></i>
                </div>
                <p class="text-[10px] font-bold text-gray-600 leading-tight">2. 情報を保存</p>
              </div>

              <%# STEP 3 %>
              <div class="flex flex-col items-center relative z-10 w-1/3">
                <div class="w-16 h-16 bg-white border border-gray-100 rounded-full shadow-md flex items-center justify-center mb-4">
                  <i class="bi bi-trash3 text-2xl text-[#11243B]"></i>
                </div>
                <p class="text-[10px] font-bold text-gray-600 leading-tight">3. パッケージを捨てる</p>
              </div>
            </div>

            <%# 🌟 追加：管理できるものの具体例（チップ形式） 🌟 %>
            <div class="mb-10">
              <p class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4 text-center">こんなものを登録してみよう</p>
              <div class="flex flex-wrap justify-center gap-2">
                <span class="px-3 py-1.5 bg-white border border-gray-100 rounded-full text-[11px] font-bold text-gray-500 shadow-sm">家電の簡易説明書</span>
                <span class="px-3 py-1.5 bg-white border border-gray-100 rounded-full text-[11px] font-bold text-gray-500 shadow-sm">たまに使う時刻表</span>
                <span class="px-3 py-1.5 bg-white border border-gray-100 rounded-full text-[11px] font-bold text-gray-500 shadow-sm">手書きの買い物リスト</span>
                <span class="px-3 py-1.5 bg-white border border-gray-100 rounded-full text-[11px] font-bold text-gray-500 shadow-sm">電球の型番</span>
                <span class="px-3 py-1.5 bg-white border border-gray-100 rounded-full text-[11px] font-bold text-gray-500 shadow-sm">薬の成分表</span>
              </div>
            </div>

            <%# 登録ボタン %>
            <%= link_to new_item_path, 
                class: "inline-flex items-center justify-center gap-2 w-full bg-[#11243B] text-white py-5 px-6 rounded-2xl text-base font-black shadow-lg hover:brightness-110 active:scale-95 transition-all" do %>
              <i class="bi bi-plus-circle text-lg"></i>
              最初の説明書を登録する
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <%# --- アイテムリスト表示 --- %>
      <% @items.each do |item| %>
        <%= link_to item_path(item), class: "bg-white p-4 rounded-3xl shadow-sm flex items-center w-full active:scale-[0.98] transition-all duration-100 border border-transparent active:border-base-border" do %>
          <div class="w-20 h-20 bg-base-bg rounded-2xl mr-4 flex-shrink-0 overflow-hidden border border-black/5 flex items-center justify-center">
            <% if item.images.attached? %>
              <%= cl_image_tag item.images.first.key, 
                  transformation: [ { width: 400, height: 400, crop: :fill }, { fetch_format: :auto, quality: :auto } ],
                  class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-gray-300">
                <i class="bi bi-image text-2xl"></i>
              </div>
            <% end %>
          </div>

          <div class="flex-grow min-w-0">
            <h3 class="font-bold text-primary text-lg leading-tight mb-2 truncate"><%= item.name %></h3>
            <% if item.category.present? %>
              <div class="inline-flex items-center justify-center h-6 px-3 rounded-full bg-accent text-primary shadow-sm border border-accent/20">
                <span class="text-[10px] font-black uppercase leading-none mt-[1px]"><%= item.category.name %></span>
              </div>
            <% end %>
          </div>

          <div class="text-[10px] text-base-text self-end pb-1 whitespace-nowrap ml-2 opacity-70 font-mono italic">
            <%= time_ago_in_words(item.updated_at) %>前
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>