<div class="bg-white h-screen overflow-hidden flex flex-col items-center px-6 py-8">
  
  <%# ヘッダー %>
  <header class="w-full py-4 text-center">
    <h1 class="text-lg font-extrabold text-primary">登録完了</h1>
  </header>

  <%# 中央のイラスト・メッセージエリア %>
  <div class="flex-grow flex flex-col items-center justify-center space-y-10 w-full">
    <%# イラストエリア %>
    <div class="w-64 h-64 flex items-center justify-center bg-slate-50 rounded-full shadow-inner">
      <i class="bi bi-trash3 text-7xl text-primary animate-bounce"></i>
    </div>

    <div class="text-center space-y-4">
      <h2 class="text-2xl font-extrabold text-primary tracking-tight">おつかれさまでした</h2>
      <p class="text-sm font-bold text-gray-500 leading-relaxed">
        持ち物がひとつ減って、<br>
        心が軽くなりましたね
      </p>
    </div>
  </div>

  <div class="w-full space-y-4 mb-16">
    <%= link_to items_path, class: "block w-full bg-primary text-white font-extrabold py-4 rounded-full text-center text-lg shadow-md active:scale-95 transition-transform" do %>
      ライブラリを見る
    <% end %>

    <%= link_to new_item_path(t: Time.now.to_i), class: "block w-full bg-white text-primary border-2 border-primary font-extrabold py-4 rounded-full text-center text-lg active:scale-95 transition-transform" do %>
      続けて登録する
    <% end %>
  </div>
</div>