<% content_for :page_title, "カテゴリの編集" %>
<% content_for :back_path, categories_path %> <%# 🌟 カテゴリ一覧に戻る %>

<div class="px-4 max-w-md mx-auto mt-6">
  <div class="bg-white p-6 rounded-3xl shadow-sm border border-base-border/30">
    <p class="text-[10px] font-black text-base-text opacity-50 uppercase tracking-widest mb-4 px-1">カテゴリ名を変更</p>
    
    <%= form_with(model: @category, class: "space-y-6") do |f| %>
      <% if @category.errors.any? %>
        <div class="bg-red-50 p-4 rounded-2xl text-red-500 text-xs font-bold">
          <ul>
            <% @category.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.text_field :name, 
            class: "w-full px-5 py-4 rounded-2xl bg-gray-50 border-none text-sm font-bold focus:ring-2 focus:ring-accent transition-all shadow-inner",
            placeholder: "例：日用品" %>
      </div>

      <div class="flex flex-col gap-3 pt-2">
        <%= f.submit "変更を保存する", 
            class: "w-full bg-primary text-white py-4 rounded-2xl font-black shadow-lg shadow-primary/20 active:scale-[0.98] transition-all text-sm" %>
        
        <%= link_to "キャンセル", categories_path, 
            class: "w-full text-center py-4 text-sm font-bold text-gray-400 active:opacity-60 transition-all" %>
      </div>
    <% end %>
  </div>
</div>